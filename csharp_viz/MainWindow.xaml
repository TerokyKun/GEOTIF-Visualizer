                        </StackPanel>
                    </Border>
                    
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource Hdr}" Text="DEBUG STATUS"/>
                            <TextBlock Style="{StaticResource Val}" Text="{Binding DebugInfo}"
                                       TextWrapping="Wrap" FontSize="10"/>
                        </StackPanel>
                    </Border> -->
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>