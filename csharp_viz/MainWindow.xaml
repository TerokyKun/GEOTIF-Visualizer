                            <TextBlock Style="{StaticResource Val}" Text="{Binding EkfX, StringFormat=F2}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Y, m:"/>
                            <TextBlock Style="{StaticResource Val}" Text="{Binding EkfY, StringFormat=F2}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Sigma X:"/>
                            <TextBlock Style="{StaticResource Val}" Text="{Binding EkfSigmaX, StringFormat=F3}"/>
                            <TextBlock Style="{StaticResource Lbl}" Text="Sigma Y:"/>
                            <TextBlock Style="{StaticResource Val}" Text="{Binding EkfSigmaY, StringFormat=F3}"/>
                        </StackPanel>
                    </Border>

                    
                    <Border Style="{StaticResource Card}">
